{
  "expo": {
    "name": "TriZone",
    "slug": "trizone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trizone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trizone.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.trizone.app",
      "adaptiveIcon": {
        "backgroundColor": "#E2231A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E2231A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "dark": {
            "backgroundColor": "#E2231A"
          }
        }
      ],
      "expo-localization",
      [
        "expo-calendar",
        {
          "calendarPermission": "TriZone fügt Rennen zu deinem Kalender hinzu."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E2231A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TriZone nutzt deinen Standort, um Triathlons in deiner Nähe zu finden."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
