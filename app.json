{
  "expo": {
    "name": "TriZone",
    "slug": "trizone",
    "owner": "trizone-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trizone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.trizone.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.trizone.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E2231A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E2231A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "dark": {
            "backgroundColor": "#E2231A"
          }
        }
      ],
      "expo-localization",
      [
        "expo-calendar",
        {
          "calendarPermission": "TriZone fügt Rennen zu deinem Kalender hinzu."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E2231A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TriZone nutzt deinen Standort, um Triathlons in deiner Nähe zu finden."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "711a8d2e-ca4d-406b-b6bc-7b667c368f64"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/711a8d2e-ca4d-406b-b6bc-7b667c368f64"
    }
  }
}
